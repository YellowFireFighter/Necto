Code Pattern Search

Copy
uint64 proc_t::find_code_pattern(
    uint64 search_start,
    uint64 search_size,
    const string &in signature
)

void proc_t::find_all_code_patterns(uint64 search_start,
 uint64 search_size, 
 const string &in signature, 
